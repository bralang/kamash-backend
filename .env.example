# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Google service account (Sheets + Drive access)
# Path to a service-account JSON key file, shared as Editor on both spreadsheets
# and the Drive root folder (1McvYAEu97nBufa4po3gxfx6eiOdjmUzH).
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# Real Workspace mailbox the service account impersonates (domain-wide delegation) so Drive
# writes use a real user's storage quota. Must be authorized for this service account's Client
# ID in admin.google.com > Security > API Controls > Domain-wide Delegation, with scopes
# https://www.googleapis.com/auth/drive and https://www.googleapis.com/auth/spreadsheets.
GOOGLE_IMPERSONATED_USER_EMAIL=bracha@link-up.co.il

# OpenAI (Whisper transcription + GPT-4.1 chat/structured output)
OPENAI_API_KEY=

# Anthropic (Claude section rewrite)
ANTHROPIC_API_KEY=
# Optional overrides — defaults shown below if unset.
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MAX_TOKENS=4096

# Gmail send (sendEmailWithDiagnosis) - filled in when that endpoint is migrated
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
